<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="确认订单"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCheckoutAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:text="正在加载默认地址"
            android:textColor="@color/black"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnManageAddress"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:text="地址管理" />

        <TextView
            android:id="@+id/tvCheckoutGoods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="正在加载商品"
            android:textColor="@color/black"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvCheckoutTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="合计：¥0"
            android:textColor="@color/red"
            android:textSize="20sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgPayType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:checkedButton="@id/rbAliPay">

            <RadioButton
                android:id="@+id/rbAliPay"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="支付宝支付" />

            <RadioButton
                android:id="@+id/rbWechatPay"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="微信支付" />
        </RadioGroup>

        <Button
            android:id="@+id/btnSubmitOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@color/red"
            android:text="生成订单"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>
