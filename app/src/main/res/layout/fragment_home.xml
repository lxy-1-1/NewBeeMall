<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/light_gray">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 轮播图区域（使用自定义 BannerContainer 解决嵌套 ViewPager2 手滑冲突） -->
            <com.example.newbeemall.widget.BannerContainer
                android:id="@+id/bannerContainer"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_surface_card">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- 轮播指示器小圆点 -->
                <LinearLayout
                    android:id="@+id/llDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal" />

                <!-- 搜索栏覆盖在轮播上 -->
                <TextView
                    android:id="@+id/tvSearch"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_margin="16dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edit_input"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="山河无恙，人间皆安"
                    android:textColor="@color/gray"
                    android:textSize="14sp" />
            </com.example.newbeemall.widget.BannerContainer>

            <!-- 导航区域（GridView） -->
            <com.example.newbeemall.widget.ExpandedGridView
                android:id="@+id/gvNav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:numColumns="5"
                android:padding="8dp"
                android:background="@drawable/bg_surface_card"
                android:layout_marginTop="10dp" />

            <!-- 新品上线标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp"
                android:text="新品上线"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 新品上线（GridView） -->
            <com.example.newbeemall.widget.ExpandedGridView
                android:id="@+id/gvNewGoods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:numColumns="2"
                android:verticalSpacing="4dp"
                android:horizontalSpacing="4dp"
                android:background="@drawable/bg_surface_card" />

            <!-- 热门商品标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp"
                android:text="热门商品"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 热门商品（GridView） -->
            <com.example.newbeemall.widget.ExpandedGridView
                android:id="@+id/gvHotGoods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:numColumns="2"
                android:verticalSpacing="4dp"
                android:horizontalSpacing="4dp"
                android:background="@drawable/bg_surface_card" />

            <!-- 最新推荐标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp"
                android:text="最新推荐"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 最新推荐（GridView） -->
            <com.example.newbeemall.widget.ExpandedGridView
                android:id="@+id/gvRecommendGoods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:numColumns="2"
                android:verticalSpacing="4dp"
                android:horizontalSpacing="4dp"
                android:background="@drawable/bg_surface_card" />

        </LinearLayout>

    </ScrollView>

    <!-- 固定标题栏（在ScrollView上方，随滚动变色） -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#001ABC9C"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="新蜂商城"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvToolbarLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="登录"
            android:textColor="@color/white"
            android:textSize="15sp" />
    </LinearLayout>

</FrameLayout>
